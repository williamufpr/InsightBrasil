library(knitr)
library(kableExtra)
dados <- data.frame(
Categoria = c("A", "B", "C"),
Quantidade = c(12, 34, 56),
Percentual = c(0.2, 0.3, 0.5)
)
kable(dados, caption = "Exemplo de Tabela") |>
kable_styling(
bootstrap_options = c("striped", "hover", "condensed", "responsive"),
full_width = FALSE,
position = "center"
)
